ggplot(mpg) +
geom_mosaic(aes(weight = 1, x = product(class, drv))) +
labs(title = "Mosaic Plot of Car Class and Drive Type")
ggplot(mpg, aes(x = displ, y = hwy, color = class)) +
geom_point() +
geom_label_repel(data = mpg %>% filter(hwy > 40), aes(label = model)) +
labs(title = "Highlighting High MPG Vehicles", x = "Displacement (L)", y = "Highway MPG")
z_scores <- scale(airquality, center = TRUE, scale = TRUE)
z_outliers <- apply(z_scores, 2, function(x) abs(x) > 3)
z_outlier_rows <- unique(which(z_outliers, arr.ind = TRUE)[,1])
outliers_z <- airquality[z_outlier_rows, ]
outliers_z
z_outlier_cols <- colnames(airquality)[colSums(z_outliers) > 0]
z_outlier_cols

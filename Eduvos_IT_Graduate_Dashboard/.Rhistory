library(dplyr)
insurance <- insurance %>%
mutate(BMI_Category = case_when(
bmi < 18.5 ~ "Underweight",
bmi >= 18.5 & bmi <= 24 ~ "Normal",
bmi > 24 & bmi < 29 ~ "Overweight",
bmi > 29 & bmi <= 40 ~ "Obese",
bmi > 40.5 ~ "Extremely Obese"
))
colnames(insurance)
